# ============================================================
# WANDR — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to Git.
# ============================================================

# ── Database (Supabase PostgreSQL) ──────────────────────────
DATABASE_URL="postgresql://postgres.xxxx:vihar@2212#password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres:vihar@2212#password@db.xxxx.supabase.co:5432/postgres"

# ── AI Providers (Multi-AI fallback: Anthropic → Groq → Gemini) ─
# Anthropic (primary) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# Groq (fallback #1) — https://console.groq.com/keys
GROQ_API_KEY=""

# Gemini (fallback #2) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# ── NextAuth / Auth.js ───────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# ── Google OAuth (optional) ──────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── GitHub OAuth (optional) ──────────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── Stripe (optional) ────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_EXPLORER_PRICE_ID=""
STRIPE_NOMAD_PRICE_ID=""

# ── App URL ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
